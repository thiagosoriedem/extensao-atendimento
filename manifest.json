{
  "manifest_version": 3,
  "name": "TextSync Ultra",
  "version": "2.0",
  "permissions": [
    "storage",
    "contextMenus",
    "scripting",
    "clipboardWrite"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*", "https://direct.neoron.io/*" ],
      "js": ["content.js"]
    },
    {
      "matches": ["https://app.medicalsys.com.br/atendimento/agenda/calendario/*"],
      "js": ["content-agenda.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["backup_padrao.json"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "128": "icone.png"
  }
}